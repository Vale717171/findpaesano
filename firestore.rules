rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function hasKey(data, key) {
      return data.keys().hasAny([key]);
    }

    function optionalString(data, key, min, max) {
      return !hasKey(data, key)
        || (
          data[key] is string
          && data[key].size() >= min
          && data[key].size() <= max
        );
    }

    function optionalNullableString(data, key, min, max) {
      return !hasKey(data, key)
        || data[key] == null
        || (
          data[key] is string
          && data[key].size() >= min
          && data[key].size() <= max
        );
    }

    function optionalTimestamp(data, key) {
      return !hasKey(data, key) || data[key] is timestamp;
    }

    function optionalGeoPoint(data, key) {
      return !hasKey(data, key) || data[key] is latlng;
    }

    function hasValidUserData(data) {
      return data.keys().hasOnly([
          'nickname',
          'countryCode',
          'countryName',
          'countryFlag',
          'travelStatus',
          'destination',
          'createdAt',
          'location',
          'locationUpdatedAt',
        ])
        && data.keys().hasAll([
          'nickname',
          'countryCode',
          'countryName',
          'countryFlag',
          'travelStatus',
          'destination',
          'createdAt',
        ])
        && data.nickname is string
        && data.nickname.size() >= 1
        && data.nickname.size() <= 20
        && optionalString(data, 'countryCode', 1, 8)
        && optionalString(data, 'countryName', 1, 80)
        && optionalString(data, 'countryFlag', 1, 16)
        && data.travelStatus in ['planning', 'here']
        && optionalNullableString(data, 'destination', 1, 120)
        && data.createdAt is timestamp
        && optionalGeoPoint(data, 'location')
        && optionalTimestamp(data, 'locationUpdatedAt');
    }

    function hasValidMessageData(data) {
      return data.keys().hasOnly([
          'text',
          'category',
          'location',
          'locationKey',
          'authorUid',
          'authorNickname',
          'authorFlag',
          'createdAt',
          'reportCount',
        ])
        && data.keys().hasAll([
          'text',
          'category',
          'location',
          'locationKey',
          'authorUid',
          'authorNickname',
          'authorFlag',
          'createdAt',
        ])
        && data.text is string
        && data.text.size() >= 1
        && data.text.size() <= 300
        && data.category in ['Food', 'Places', 'Transport', 'Warning', 'Other']
        && data.location is string
        && data.location.size() >= 1
        && data.location.size() <= 120
        && data.locationKey is string
        && data.locationKey.size() >= 1
        && data.locationKey.size() <= 120
        && data.authorUid is string
        && data.authorUid.size() >= 1
        && data.authorNickname is string
        && data.authorNickname.size() >= 1
        && data.authorNickname.size() <= 20
        && data.authorFlag is string
        && data.authorFlag.size() >= 1
        && data.authorFlag.size() <= 16
        && data.createdAt is timestamp
        && (
          !hasKey(data, 'reportCount')
          || (data.reportCount is int && data.reportCount == 0)
        );
    }

    function hasValidChatRequestData(data) {
      return data.keys().hasOnly([
          'fromUid',
          'fromNickname',
          'fromFlag',
          'toUid',
          'toNickname',
          'toFlag',
          'status',
          'createdAt',
          'chatId',
        ])
        && data.keys().hasAll([
          'fromUid',
          'fromNickname',
          'fromFlag',
          'toUid',
          'toNickname',
          'toFlag',
          'status',
          'createdAt',
        ])
        && data.fromUid is string
        && data.fromUid.size() >= 1
        && data.toUid is string
        && data.toUid.size() >= 1
        && data.fromUid != data.toUid
        && data.fromNickname is string
        && data.fromNickname.size() >= 1
        && data.fromNickname.size() <= 20
        && data.toNickname is string
        && data.toNickname.size() >= 1
        && data.toNickname.size() <= 20
        && data.fromFlag is string
        && data.fromFlag.size() >= 1
        && data.fromFlag.size() <= 16
        && data.toFlag is string
        && data.toFlag.size() >= 1
        && data.toFlag.size() <= 16
        && data.status in ['pending', 'accepted', 'declined']
        && data.createdAt is timestamp
        && (
          !hasKey(data, 'chatId')
          || (data.chatId is string && data.chatId.size() >= 1)
        );
    }

    function hasValidChatCreateData(data) {
      return data.keys().hasOnly([
          'participants',
          'participantFlags',
          'participantNicknames',
          'createdAt',
          'lastMessageAt',
          'lastMessage',
          'closedBy',
          'closedAt',
        ])
        && data.keys().hasAll([
          'participants',
          'participantFlags',
          'participantNicknames',
          'createdAt',
          'lastMessageAt',
        ])
        && data.participants is list
        && data.participants.size() == 2
        && data.participants[0] is string
        && data.participants[0].size() >= 1
        && data.participants[1] is string
        && data.participants[1].size() >= 1
        && data.participants[0] != data.participants[1]
        && data.participantFlags is map
        && data.participantFlags.keys().hasOnly([
          data.participants[0],
          data.participants[1],
        ])
        && data.participantFlags[data.participants[0]] is string
        && data.participantFlags[data.participants[0]].size() >= 1
        && data.participantFlags[data.participants[0]].size() <= 16
        && data.participantFlags[data.participants[1]] is string
        && data.participantFlags[data.participants[1]].size() >= 1
        && data.participantFlags[data.participants[1]].size() <= 16
        && data.participantNicknames is map
        && data.participantNicknames.keys().hasOnly([
          data.participants[0],
          data.participants[1],
        ])
        && data.participantNicknames[data.participants[0]] is string
        && data.participantNicknames[data.participants[0]].size() >= 1
        && data.participantNicknames[data.participants[0]].size() <= 20
        && data.participantNicknames[data.participants[1]] is string
        && data.participantNicknames[data.participants[1]].size() >= 1
        && data.participantNicknames[data.participants[1]].size() <= 20
        && data.createdAt is timestamp
        && data.lastMessageAt is timestamp
        && !hasKey(data, 'lastMessage')
        && !hasKey(data, 'closedBy')
        && !hasKey(data, 'closedAt');
    }

    function isChatParticipant(chatData) {
      return isAuth() && uid() in chatData.participants;
    }

    // ─────────────────────────────────────────
    // Users  /users/{userId}
    // ─────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && uid() == userId
        && hasValidUserData(request.resource.data)
        && request.resource.data.createdAt == request.time;

      allow update: if isAuth()
        && uid() == userId
        && hasValidUserData(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isAuth() && uid() == userId;

      match /blockedUsers/{blockedUid} {
        allow read: if isAuth() && uid() == userId;

        allow create, update: if isAuth()
          && uid() == userId
          && blockedUid != uid()
          && request.resource.data.keys().hasOnly(['blockedAt'])
          && request.resource.data.keys().hasAll(['blockedAt'])
          && request.resource.data.blockedAt is timestamp
          && request.resource.data.blockedAt == request.time;

        allow delete: if isAuth() && uid() == userId;
      }
    }

    // ─────────────────────────────────────────
    // Board messages  /messages/{messageId}
    // ─────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.authorUid == uid()
        && hasValidMessageData(request.resource.data)
        && request.resource.data.createdAt == request.time;

      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount'])
        && request.resource.data.reportCount is int
        && resource.data.authorUid != uid()
        && request.resource.data.reportCount == resource.data.get('reportCount', 0) + 1;

      allow delete: if isAuth() && resource.data.authorUid == uid();
    }

    // ─────────────────────────────────────────
    // Reports  /reports/{reportId}
    // ─────────────────────────────────────────
    match /reports/{reportId} {
      // The Flutter client reads only the current user's reports to avoid
      // duplicate reporting. Keep this narrow until reports are moved to a
      // deterministic path or handled server-side.
      allow read: if isAuth() && resource.data.reportedBy == uid();

      allow create: if isAuth()
        && request.resource.data.keys().hasOnly(['messageId', 'reportedBy', 'createdAt'])
        && request.resource.data.keys().hasAll(['messageId', 'reportedBy', 'createdAt'])
        && request.resource.data.messageId is string
        && request.resource.data.messageId.size() >= 1
        && request.resource.data.reportedBy == uid()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAt == request.time
        && exists(/databases/$(database)/documents/messages/$(request.resource.data.messageId))
        && get(/databases/$(database)/documents/messages/$(request.resource.data.messageId)).data.authorUid != uid();

      allow update, delete: if false;
    }

    // ─────────────────────────────────────────
    // Chat requests  /chatRequests/{requestId}
    // ─────────────────────────────────────────
    match /chatRequests/{requestId} {
      allow read: if isAuth()
        && (resource.data.fromUid == uid() || resource.data.toUid == uid());

      allow create: if isAuth()
        && hasValidChatRequestData(request.resource.data)
        && request.resource.data.fromUid == uid()
        && request.resource.data.status == 'pending'
        && !hasKey(request.resource.data, 'chatId')
        && request.resource.data.createdAt == request.time;

      allow update: if isAuth()
        && resource.data.toUid == uid()
        && hasValidChatRequestData(request.resource.data)
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.fromNickname == resource.data.fromNickname
        && request.resource.data.fromFlag == resource.data.fromFlag
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.toNickname == resource.data.toNickname
        && request.resource.data.toFlag == resource.data.toFlag
        && request.resource.data.createdAt == resource.data.createdAt
        && resource.data.status == 'pending'
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && request.resource.data.status == 'declined'
            && !hasKey(request.resource.data, 'chatId')
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'chatId'])
            && request.resource.data.status == 'accepted'
            && hasKey(request.resource.data, 'chatId')
            && request.resource.data.chatId is string
            && request.resource.data.chatId.size() >= 1
          )
        );

      allow delete: if isAuth()
        && (resource.data.fromUid == uid() || resource.data.toUid == uid());
    }

    // ─────────────────────────────────────────
    // Chats  /chats/{chatId}
    // ─────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isChatParticipant(resource.data);

      allow create: if isAuth()
        && hasValidChatCreateData(request.resource.data)
        && uid() in request.resource.data.participants
        && request.resource.data.createdAt == request.time
        && request.resource.data.lastMessageAt == request.time;

      allow update: if isChatParticipant(resource.data)
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.participantFlags == resource.data.participantFlags
        && request.resource.data.participantNicknames == resource.data.participantNicknames
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt'])
            && request.resource.data.lastMessage is string
            && request.resource.data.lastMessage.size() >= 1
            && request.resource.data.lastMessage.size() <= 500
            && request.resource.data.lastMessageAt is timestamp
            && (
              !hasKey(resource.data, 'closedBy')
              || request.resource.data.closedBy == resource.data.closedBy
            )
            && (
              !hasKey(resource.data, 'closedAt')
              || request.resource.data.closedAt == resource.data.closedAt
            )
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['closedBy', 'closedAt'])
            && request.resource.data.closedBy == uid()
            && request.resource.data.closedAt is timestamp
            && (
              !hasKey(resource.data, 'lastMessage')
              || request.resource.data.lastMessage == resource.data.lastMessage
            )
            && request.resource.data.lastMessageAt == resource.data.lastMessageAt
          )
        );

      // TODO: keep delete open to participants for now because the current
      // account-deletion flow removes shared chats client-side. Move this
      // cleanup to a privileged backend path in a follow-up PR, then close it.
      allow delete: if isChatParticipant(resource.data);

      match /messages/{messageId} {
        allow read: if isChatParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data
        );

        allow create: if isChatParticipant(
            get(/databases/$(database)/documents/chats/$(chatId)).data
          )
          && request.resource.data.keys().hasOnly(['text', 'senderUid', 'createdAt'])
          && request.resource.data.keys().hasAll(['text', 'senderUid', 'createdAt'])
          && request.resource.data.senderUid == uid()
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 500
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdAt == request.time;

        allow update: if false;

        // TODO: keep delete open to participants for now because the current
        // account-deletion flow deletes chat messages client-side. Close this
        // once cleanup moves to a privileged backend path.
        allow delete: if isChatParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data
        );
      }
    }
  }
}
